# SupplyChain AI environment

# Local backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8010

# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8010
NEXT_PUBLIC_API_HOST=127.0.0.1
NEXT_PUBLIC_API_PORT=8010
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
ALLOW_DEV_AUTH_FALLBACK=true
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_REASONING_EFFORT=low
AI_AUTO_ORDER_DRAFT_FIRST=true
AI_AUTO_ORDER_MAX_SPEND=250000

# Email alerts for critical SKUs
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SupplyChain AI

# Future cloud config
DEFAULT_AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=supplychain-ai-workspaces
DYNAMODB_AUTO_CREATE=true
DYNAMODB_ENDPOINT_URL=
# Local development defaults to file mode; non-dev environments should prefer DynamoDB.
DYNAMODB_USE_REMOTE=false
DYNAMODB_USE_LOCAL=true
DYNAMODB_FALLBACK_TO_FILE=true
CLERK_JWKS_URL=
CLERK_ISSUER=
