# SupplyChain AI production environment

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8010

NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER=
CLERK_JWKS_URL=
ALLOW_DEV_AUTH_FALLBACK=false
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_REASONING_EFFORT=low
AI_AUTO_ORDER_DRAFT_FIRST=true
AI_AUTO_ORDER_MAX_SPEND=250000

RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@yourdomain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SupplyChain AI

DEFAULT_AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=supplychain-ai-workspaces
DYNAMODB_AUTO_CREATE=false
DYNAMODB_ENDPOINT_URL=
DYNAMODB_USE_REMOTE=true
DYNAMODB_USE_LOCAL=false
DYNAMODB_FALLBACK_TO_FILE=false

CORS_ORIGINS=https://yourdomain.com
